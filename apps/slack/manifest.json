{
  "_metadata": {
    "major_version": 1,
    "minor_version": 1
  },
  "display_information": {
    "name": "Legendary Hunts",
    "description": "Gamified certification prep. Daily quizzes in Slack, hunts and battles on the web.",
    "background_color": "#1a1a2e"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": false,
      "messages_tab_read_only_enabled": true
    },
    "bot_user": {
      "display_name": "Legendary Hunts",
      "always_online": false
    },
    "shortcuts": [
      {
        "name": "Start daily quiz",
        "type": "global",
        "callback_id": "start_daily_quiz",
        "description": "Get today's certification practice question"
      },
      {
        "name": "Open Legendary Hunts",
        "type": "global",
        "callback_id": "open_web_hunt",
        "description": "Open the web app to start a hunt"
      }
    ],
    "slash_commands": [
      {
        "command": "/legendary",
        "description": "Legendary Hunts — daily quiz and certification prep",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "channels:history",
        "chat:write",
        "commands",
        "im:write",
        "users:read",
        "app_mentions:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": ["app_home_opened"]
    },
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": true,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
