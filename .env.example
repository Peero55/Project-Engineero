# Legendary Hunts — Environment Variables
# Copy to .env.local and fill in your values.

# Shared
NODE_ENV=development
APP_NAME=Legendary Hunts
WEB_APP_URL=http://localhost:3000
SLACK_APP_URL=http://localhost:3001

# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Web admin (Phase 5 — question review at /admin/login; use openssl rand -hex 32)
ADMIN_API_SECRET=

# Slack (Socket Mode — get from api.slack.com/apps)
# Signing Secret: Basic Information
# Bot Token & App Token: OAuth & Permissions / App-Level Tokens
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# OAuth mode (optional — for multi-workspace install)
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_STATE_SECRET=
# SLACK_REDIRECT_URI=http://localhost:3001/slack/oauth_redirect

# Auth (generate: openssl rand -hex 32)
SESSION_SECRET=your-session-secret

# Optional: shared secret for Slack → Next.js daily-question API (set in apps/slack too)
# INTERNAL_API_SECRET=

# Optional
OPENAI_API_KEY=
ASSET_CDN_URL=
