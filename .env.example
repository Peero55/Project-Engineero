# Engineero — example environment variables
# Copy to .env.local (or your team’s convention) and fill in values.
# Never commit real secrets. This file is safe to commit.

# --- App / runtime ---
# Public base URL of the web app (used for links, callbacks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment: development | test | production
NODE_ENV=development

# If the API runs as a separate Node process (adjust when architecture is finalized)
API_PORT=3001

# --- Database (PostgreSQL) ---
# Connection string format varies by host; replace placeholders when your DB is provisioned
# Example: postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/engineero_dev

# --- Authentication (optional — enable when auth provider is chosen) ---
# AUTH_SECRET=
# NEXT_PUBLIC_AUTH_PUBLISHABLE_KEY=
# AUTH_PROVIDER_ISSUER_URL=

# --- Slack integration (optional — future use) ---
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=
# SLACK_APP_ID=

# --- Storage / assets (optional — future use) ---
# Object storage or CDN base URL for public assets (if applicable)
# ASSET_PUBLIC_BASE_URL=
# Storage provider credentials (names TBD when provider is chosen)
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# STORAGE_BUCKET=
# STORAGE_REGION=
