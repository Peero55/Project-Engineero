# Engineero — example environment variables
# Copy to .env (or .env.local) and fill in values.
# Never commit real secrets. This file is safe to commit.

# --- App / runtime ---
# Public base URL of the web app (used for links, callbacks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment: development | test | production
NODE_ENV=development

# If the API runs as a separate Node process (adjust when architecture is finalized)
API_PORT=3001

# --- Database (PostgreSQL) ---
# Connection string format varies by host; replace placeholders when your DB is provisioned
# Example: postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# --- Supabase (required) ---
# Obtain these values from the output of `supabase start`.
# Look for "API URL", "anon key", and "service_role key" in the terminal output.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-start
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-from-supabase-start
SUPABASE_JWT_KEY=your-jwt-secret-from-supabase-start
# LEGACY_ANON_KEY=your-legacy-anon-key-if-needed

# --- Authentication (optional — enable when auth provider is chosen) ---
# AUTH_SECRET=
# NEXT_PUBLIC_AUTH_PUBLISHABLE_KEY=
# AUTH_PROVIDER_ISSUER_URL=

# --- Slack integration (required) ---
# Create and configure a Slack app following docs/SLACK_SETUP.md.
# All three tokens below are required for apps/slack to start (validated by zod in env.ts).
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-level-token

# --- Storage / assets (optional — future use) ---
# Object storage or CDN base URL for public assets (if applicable)
# ASSET_PUBLIC_BASE_URL=

# --- Amazon Nova Act (optional — browser automation) ---
# Get your API key from https://nova.amazon.com/act
# NOVA_API_KEY=
# NOVA_ACT_API_KEY=

# Storage provider credentials (names TBD when provider is chosen)
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# STORAGE_BUCKET=
# STORAGE_REGION=
